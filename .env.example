## 服务器

# 服务监听端口（默认 13000）
# PORT=13000

# 绑定地址（生产环境建议显式设置）
# HOST=localhost

# 允许局域网访问（生产环境设为 false）
# ALLOW_LAN=true

# 应用基础 URL（用于回调地址拼接）
# APP_BASE_URL=http://localhost:13000

# CORS 允许来源
# CORS_ORIGIN=

# JSON 请求体大小限制
# API_JSON_LIMIT=20mb

# API 鉴权令牌（为空时自动生成并打印到日志）
# API_TOKEN=

# 日志级别：debug | info | warn | error
# LOG_LEVEL=info

## 数据库

# 数据库连接串（默认使用 SQLite 文件数据库）
# DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_novel

# 数据库模式：sqlite | postgresql
# AI_NOVEL_DATABASE_MODE=sqlite

# SQLite WAL 模式
# SQLITE_ENABLE_WAL=true

# SQLite 忙等待超时（毫秒）
# SQLITE_BUSY_TIMEOUT_MS=5000

## LLM 全局

# LLM 请求全局超时（毫秒）
# LLM_REQUEST_TIMEOUT_MS=300000

# LLM 调试日志（生产环境务必关闭）
# LLM_DEBUG_LOG=false

# LLM 调试文件日志
# LLM_DEBUG_FILE_LOG=false

# Anthropic API 版本头
# ANTHROPIC_VERSION=2023-06-01

# 循环检测器
# LOOP_DETECTOR_ENABLED=true
# LOOP_DETECTOR_WINDOW_SIZE=100
# LOOP_DETECTOR_NGRAM_SIZE=5
# LOOP_DETECTOR_REPETITION_THRESHOLD=3
# LOOP_DETECTOR_CONSECUTIVE_HIT_COUNT=3
# LOOP_DETECTOR_MIN_VALID_CONTENT_LENGTH=50

# 重复检测器
# REPETITION_DETECTION_ENABLED=true
# REPETITION_WINDOW_SIZE=200
# REPETITION_THRESHOLD=3
# REPETITION_RECOVERY_ENABLED=true

## 图片生成

# 图片生成 HTTP 超时（毫秒）
# IMAGE_GENERATION_HTTP_TIMEOUT_MS=300000

## 图片存储

# 图片存储驱动：local | s3
# IMAGE_STORAGE_DRIVER=local

# 本地存储根目录
# IMAGE_STORAGE_ROOT=storage/generated-images

# S3 / MinIO 配置
# IMAGE_STORAGE_S3_ENDPOINT=
# IMAGE_STORAGE_S3_REGION=us-east-1
# IMAGE_STORAGE_S3_BUCKET=
# IMAGE_STORAGE_S3_ACCESS_KEY_ID=
# IMAGE_STORAGE_S3_SECRET_ACCESS_KEY=
# IMAGE_STORAGE_S3_FORCE_PATH_STYLE=true

# MinIO 兼容别名（优先使用上方 IMAGE_STORAGE_S3_* 配置）
# MINIO_ENDPOINT=
# MINIO_REGION=us-east-1
# MINIO_BUCKET=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_FORCE_PATH_STYLE=true

## RAG（知识库检索增强）

# 启用 RAG（设为 false 可完全跳过向量检索）
# RAG_ENABLED=true

# RAG 调试日志
# RAG_VERBOSE_LOG=false

# Qdrant 向量数据库
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=ai_novel_chunks_v1
# QDRANT_TIMEOUT_MS=30000
# QDRANT_UPSERT_MAX_BYTES=25165824

# 嵌入模型配置
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_VERSION=1
# EMBEDDING_BATCH_SIZE=64

# SiliconFlow 嵌入模型（备选）
# SILICONFLOW_EMBEDDING_MODEL=

# OpenAI 嵌入模型（备选）
# OPENAI_EMBEDDING_MODEL=

# RAG 文本分块
# RAG_CHUNK_SIZE=800
# RAG_CHUNK_OVERLAP=120

# RAG 检索参数
# RAG_VECTOR_CANDIDATES=40
# RAG_KEYWORD_CANDIDATES=40
# RAG_FINAL_TOP_K=8

# RAG 嵌入超时与重试
# RAG_EMBEDDING_TIMEOUT_MS=30000
# RAG_EMBEDDING_MAX_RETRIES=2
# RAG_EMBEDDING_RETRY_BASE_MS=500

# RAG Worker
# RAG_WORKER_POLL_MS=2500
# RAG_WORKER_MAX_ATTEMPTS=5
# RAG_WORKER_RETRY_BASE_MS=5000
# RAG_HTTP_TIMEOUT_MS=30000

## 自动导演

# 自动导演过期运行任务恢复（毫秒）
# AUTO_DIRECTOR_STALE_RUNNING_TASK_MS=

# 导演 Worker ID
# DIRECTOR_WORKER_ID=

# 导演调试日志
# DIRECTOR_DEBUG_LOG_ENABLED=true
# DIRECTOR_DEBUG_LOG_DETAIL_LEVEL=standard
# DIRECTOR_DEBUG_LOG_RETENTION_HOURS=168

## 写法引擎

# 写法引擎超时（毫秒）
# STYLE_EXTRACTION_LLM_TIMEOUT_MS=

# 写法提取任务心跳间隔（毫秒）
# STYLE_EXTRACTION_TASK_HEARTBEAT_INTERVAL_MS=

## 自动导演通知渠道

# 应用基础 URL（用于钉钉/企微回调地址）
# AUTO_DIRECTOR_DINGTALK_WEBHOOK_URL=
# AUTO_DIRECTOR_DINGTALK_CALLBACK_TOKEN=
# AUTO_DIRECTOR_DINGTALK_OPERATOR_MAP_JSON=
# AUTO_DIRECTOR_DINGTALK_EVENT_TYPES=
# AUTO_DIRECTOR_WECOM_WEBHOOK_URL=
# AUTO_DIRECTOR_WECOM_CALLBACK_TOKEN=
# AUTO_DIRECTOR_WECOM_OPERATOR_MAP_JSON=
# AUTO_DIRECTOR_WECOM_EVENT_TYPES=

## 书籍分析

# BOOK_ANALYSIS_MAX_CONCURRENT_TASKS=2
# BOOK_ANALYSIS_NOTES_CONCURRENCY=2
# BOOK_ANALYSIS_SECTION_CONCURRENCY=2
# BOOK_ANALYSIS_CACHE_SEGMENT_VERSION=1

## 侧效应 Worker

# NOVEL_SIDE_EFFECT_WORKER_ID=

## 工具调用循环阈值

# TOOL_CALL_LOOP_THRESHOLD=3

## LLM 调试文件路径

# RUN_WITH_LOG_PATH=
# RUN_WITH_LOG_LLM_PATH=
# RUN_WITH_LOG_LLM_REPAIR_PATH=

## 运行环境

# NODE_ENV=development

# 应用数据目录（桌面端自动检测）
# AI_NOVEL_APP_DATA_DIR=

# 运行时类型：web | desktop
# AI_NOVEL_RUNTIME=web

## 功能开关

# 世界向导（默认开启）
# WORLD_WIZARD_ENABLED=true

# 世界可视化（默认开启）
# WORLD_VIS_ENABLED=true

# 世界图谱（默认关闭）
# WORLD_GRAPH_ENABLED=false

## 图片模型（各厂商）

# OPENAI_IMAGE_MODEL=
# SILICONFLOW_IMAGE_MODEL=
# XAI_IMAGE_MODEL=
# MINIMAX_IMAGE_MODEL=
# MINIMAX_IMAGE_BASE_URL=https://api.minimaxi.com

## 厂商 Base URL

# DEEPSEEK_BASE_URL=
# SILICONFLOW_BASE_URL=
# KIMI_BASE_URL=

## 客户端环境变量（client/.env）

# VITE_API_BASE_URL=http://localhost:13000/api
