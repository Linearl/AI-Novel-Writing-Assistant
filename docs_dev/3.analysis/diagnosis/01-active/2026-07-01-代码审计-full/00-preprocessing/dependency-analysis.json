  "configModules": {
    "database.ts": {
      "description": "数据库配置 - 支持 SQLite/PostgreSQL 双模式切换",
      "envVars": ["AI_NOVEL_DATABASE_MODE", "DATABASE_URL", "NODE_ENV"],
      "defaults": {
        "provider": "sqlite",
        "url": "file:./dev.db",
        "postgresUrl": "postgresql://postgres:postgres@127.0.0.1:5432/ai_novel"
      },
      "securityNotes": [
        "默认 Postgres 凭据硬编码在源码中 (postgres:postgres)，仅用于开发默认值",
        "生产环境要求显式设置 DATABASE_URL，否则抛出异常"
      ]
    },
    "rag.ts": {
      "description": "RAG (检索增强生成) 配置",
      "envVars": [
        "RAG_ENABLED", "RAG_VERBOSE_LOG", "RAG_DEFAULT_TENANT",
        "EMBEDDING_PROVIDER", "EMBEDDING_MODEL", "EMBEDDING_VERSION",
        "EMBEDDING_BATCH_SIZE", "RAG_EMBEDDING_TIMEOUT_MS", "RAG_EMBEDDING_MAX_RETRIES",
        "RAG_EMBEDDING_RETRY_BASE_MS", "QDRANT_URL", "QDRANT_API_KEY",
        "QDRANT_COLLECTION", "QDRANT_TIMEOUT_MS", "QDRANT_UPSERT_MAX_BYTES",
        "RAG_CHUNK_SIZE", "RAG_CHUNK_OVERLAP", "RAG_VECTOR_CANDIDATES",
        "RAG_KEYWORD_CANDIDATES", "RAG_FINAL_TOP_K", "RAG_WORKER_POLL_MS",
        "RAG_WORKER_MAX_ATTEMPTS", "RAG_WORKER_RETRY_BASE_MS", "RAG_HTTP_TIMEOUT_MS",
        "SILICONFLOW_EMBEDDING_MODEL", "OPENAI_EMBEDDING_MODEL"
      ],
      "defaults": {
        "enabled": true,
        "qdrantUrl": "http://127.0.0.1:6333",
        "embeddingProvider": "openai",
        "embeddingModel": "text-embedding-3-small",
        "chunkSize": 800,
        "finalTopK": 8
      },
      "securityNotes": [
        "QDRANT_API_KEY 默认为空字符串 - 应确保生产环境配置",
        "QDRANT_URL 默认指向 localhost - 生产部署需更改"
      ]
    },
    "featureFlags.ts": {
      "description": "功能开关配置",
      "envVars": ["WORLD_WIZARD_ENABLED", "WORLD_VIS_ENABLED", "WORLD_GRAPH_ENABLED"],
      "defaults": {
        "worldWizardEnabled": true,
        "worldVisEnabled": true,
        "worldGraphEnabled": false
      }
    },
    "imageGeneration.ts": {
      "description": "图片生成超时配置",
      "envVars": ["LLM_REQUEST_TIMEOUT_MS", "IMAGE_GENERATION_HTTP_TIMEOUT_MS"],
      "defaults": {
        "httpTimeoutMs": 300000
      }
    },
    "imageStorage.ts": {
      "description": "图片存储配置 - 支持 local/S3 双驱动",
      "envVars": [
        "IMAGE_STORAGE_DRIVER", "IMAGE_STORAGE_ROOT",
        "IMAGE_STORAGE_S3_ENDPOINT", "IMAGE_STORAGE_S3_REGION",
        "IMAGE_STORAGE_S3_BUCKET", "IMAGE_STORAGE_S3_ACCESS_KEY_ID",
        "IMAGE_STORAGE_S3_SECRET_ACCESS_KEY", "IMAGE_STORAGE_S3_FORCE_PATH_STYLE",
        "MINIO_ENDPOINT", "MINIO_REGION", "MINIO_BUCKET",
        "MINIO_ACCESS_KEY", "MINIO_SECRET_KEY", "MINIO_FORCE_PATH_STYLE"
      ],
      "defaults": {
        "driver": "local",
        "localRoot": "storage/generated-images"
      },
      "securityNotes": [
        "S3 凭据通过环境变量读取，未发现硬编码泄露",
        "兼容 MinIO 配置别名"
      ]
    },
    "directorDebug.ts": {
      "description": "导演调试日志配置",
      "envVars": [
        "DIRECTOR_DEBUG_LOG_ENABLED",
        "DIRECTOR_DEBUG_LOG_DETAIL_LEVEL",
        "DIRECTOR_DEBUG_LOG_RETENTION_HOURS"
      ],
      "defaults": {
        "enabled": true,
        "detailLevel": "standard",
        "retentionHours": 168
      }
    }
